flowchart LR
    Start(["_refresh_one_page"]) --> Read["read existing page"]
    Read --> Resolve["resolve owning service\n(DB-naming convention)"]
    Resolve --> Pull["analyze_code\nproduces analysis_summary"]
    Pull --> Skip{"page_hash and\nside_info_revision\nboth unchanged?"}
    Skip -->|"yes, not force"| ExitU(["span = unchanged"])
    Skip -->|"no, or force"| Hint["classify_by_path\npicks page_kind hint"]
    Hint --> Detect["detect_gaps LLM\nclassify + propose sections\nstrategy = source or rag per gap"]
    Detect --> Loop["for each gap"]
    Loop --> Strat{"strategy?"}
    Strat -->|source| Compose["prose-LLM\non analysis JSON"]
    Strat -->|rag| Retrieve["RAG_MCP.retrieve\ndomain_filter=sd"]
    Retrieve --> Quality{"ok?"}
    Quality -->|ok| Filled
    Quality -->|"low_conf or exhausted"| SME["SME-PLACEHOLDER block\nquestion_id fenced"]
    Compose --> Filled["FilledGap"]
    SME --> Filled
    Filled --> Loop
    Loop --> Merge["merge_into_existing\nSAFETY: never overwrite\nsubstantive prose"]
    Merge --> Index["RAG_MCP.index domain=sd"]
    Index --> Persist["upsert doc_index\nside_info_revision\nanswered_sme_blocks"]
    Persist --> ExitE(["span = enriched or escalated_only"])
