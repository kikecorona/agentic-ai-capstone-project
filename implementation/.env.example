# --- Ollama ----------------------------------------------------------------
# Local Ollama server. Default works on a workstation; override if needed.
OLLAMA_HOST=http://localhost:11434

# Model used for every LLM call (router, grader, rewriter, ToT probe,
# faithfulness re-grade, prose generation). Per architecture §8.6 the POC
# runs on llama3.1:8b. Swap to llama3.1:70b or mixtral:8x7b when graders
# need more discrimination.
LLM_MODEL=llama3.1:8b

# --- Storage paths ---------------------------------------------------------
# Where the OTel MCP collector persists spans (SQLite).
OTEL_DB_PATH=./data/otel/spans.db

# Where the in-service audit log persists (SQLite). Holds two tables:
#   - llm_calls    — every chat invoke routed through src.shared.llm.LoggedLLM
#                    (module, request, response, started_at, latency_ms, model, error)
#   - service_logs — Java-style service log entries via src.shared.service_log
#                    (module, level [info|warn|error|debug], timestamp, message)
# Inspect with `python -m src.shared.llm_log --summary` or
# `python -m src.shared.service_log --module rag.service`.
AUDIT_DB_PATH=./data/audit/log.db

# Where Chroma persists its on-disk store. The RAG Service is the only
# component that reads/writes this path.
RAG_CHROMA_PATH=./data/rag/chroma

# --- B&P Service paths -----------------------------------------------------
# Read-only org input docs root (where the agent ingests from). In production
# this is replaced by the GitHub MCP-backed PageStore reading documentation/
# inputs/ in the docs repo.
BP_INPUTS_ROOT=./data/bp/inputs

# Generated B&P pages root (where the agent writes pages). Production target
# is documentation/bp/ inside the docs repo, written through the GitHub MCP.
BP_PAGES_ROOT=./data/bp/pages

# B&P doc index + sources inventory (SQLite).
BP_DB_PATH=./data/bp/state.db

# Optional JSON file mapping product_id → [{service, page_uri, role}, ...]
# used by the StubSDClient until the real SD specialist lands.
# BP_SD_STUB_MAPPING_FILE=./data/bp/sd_stub.json

# --- SD Service paths ------------------------------------------------------
# Read-only source-tree fixtures (one immediate subdirectory per service).
# Production reads through the GitHub MCP-backed SourceStore.
SD_SOURCES_ROOT=./data/sd/sources

# Generated SD pages root. Production target is documentation/sd/ inside
# the docs repo, written through the GitHub MCP.
SD_PAGES_ROOT=./data/sd/pages

# SD doc index + sources inventory (SQLite).
SD_DB_PATH=./data/sd/state.db

# --- Orchestrator paths ----------------------------------------------------
# Pending SME questions queue + async tasks tracker (SQLite).
OC_DB_PATH=./data/orchestrator/state.db

# Bind address for the Orchestrator REST API.
OC_HOST=127.0.0.1
OC_PORT=8000

# --- Multi-process layout (start_all.sh) ----------------------------------
# Each MCP server binds host:port and exposes streamable-http at /mcp.
# Peer URLs below are what each service points at to reach the others.
# Single-process validation scripts ignore them.
OTEL_MCP_HOST=127.0.0.1
OTEL_MCP_PORT=8101
RAG_MCP_HOST=127.0.0.1
RAG_MCP_PORT=8102
BP_MCP_HOST=127.0.0.1
BP_MCP_PORT=8103
SD_MCP_HOST=127.0.0.1
SD_MCP_PORT=8104

# Peer URLs — set these (or let start_all.sh export them) to switch a
# service from in-process / stub clients to real MCP-HTTP clients.
# OTEL_MCP_URL=http://127.0.0.1:8101/mcp
# RAG_MCP_URL=http://127.0.0.1:8102/mcp
# BP_MCP_URL=http://127.0.0.1:8103/mcp
# SD_MCP_URL=http://127.0.0.1:8104/mcp

# --- GitHub MCP (production PageStore + SourceStore) -----------------------
# When all three are set, BP and SD switch every read AND write from the
# filesystem-backed Local* stores to the upstream `@modelcontextprotocol/
# server-github` MCP. Each service spawns its own GitHub MCP subprocess
# via `npx`, so Node.js must be on PATH.
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_replace_me
# GITHUB_OWNER=kikecorona
# GITHUB_REPO=pear-store
# GITHUB_BRANCH=main

# Optional path overrides — defaults match §8.5's documentation/bp/ +
# documentation/sd/ layout. SD_SOURCES_GH_PATH is the root under which
# each immediate subdirectory is treated as a service tree.
# BP_INPUTS_GH_PATH=documentation/bp
# BP_PAGES_GH_PATH=documentation/bp
# SD_PAGES_GH_PATH=documentation/sd
# SD_SOURCES_GH_PATH=implementation

# --- reset_state.sh knobs --------------------------------------------------
# Local checkout of the docs repo and the tag to reset back to. Must be a
# regular `git clone` with the configured remote already pushable.
# PEARSTORE_REPO_PATH=../../pear-store
# PEARSTORE_RESET_TAG=starting-point
# PEARSTORE_REMOTE=origin
# PEARSTORE_BRANCH=main

# --- RAG knobs (override defaults from architecture spec) ------------------
# Auto-RAG rewrite cap (§9.1.3.1).
RAG_REWRITE_BUDGET=2

# ToT chunking selector caps (§9.1.3.2 / §7.4).
RAG_TOT_K=4
RAG_TOT_BEAM=2
RAG_TOT_DEPTH=2

# Top-K for similarity retrieval (§9.1.3.1: K small since we pull whole docs).
RAG_TOP_K=4

# Grader threshold (0–3). Below threshold triggers rewrite.
RAG_GRADE_THRESHOLD=2.0
