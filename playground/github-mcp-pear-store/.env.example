# GitHub PAT with repo (or public_repo) scope. The reference
# @modelcontextprotocol/server-github MCP reads it from this env var.
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_replace_me

# Target repo (the docs repo for the Capstone POC, per §8.5).
GITHUB_OWNER=kikecorona
GITHUB_REPO=pear-store
GITHUB_BRANCH=main

# Local Ollama model the agent loop uses.
LLM_MODEL=llama3.1
